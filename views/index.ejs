<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Annotation ID Extractor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: #0f1117;
      color: #e2e8f0;
      min-height: 100vh;
      padding: 32px 16px;
    }

    .page-wrapper {
      max-width: 1000px;
      margin: 0 auto;
    }

    /* ── Header ── */
    .header {
      text-align: center;
      margin-bottom: 36px;
    }

    .header h1 {
      font-size: 2rem;
      font-weight: 700;
      background: linear-gradient(135deg, #60a5fa, #a78bfa, #f472b6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 8px;
    }

    .header p {
      color: #64748b;
      font-size: 0.95rem;
    }

    /* ── Card ── */
    .card {
      background: #1e2130;
      border: 1px solid #2d3148;
      border-radius: 16px;
      padding: 28px;
      margin-bottom: 24px;
    }

    .card-title {
      font-size: 1rem;
      font-weight: 600;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-bottom: 16px;
    }

    /* ── Error banner ── */
    .error-banner {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.4);
      color: #fca5a5;
      padding: 14px 18px;
      border-radius: 10px;
      margin-bottom: 20px;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .error-banner::before {
      content: "⚠";
      font-size: 1rem;
    }

    /* ── Form ── */
    label {
      display: block;
      font-size: 0.88rem;
      font-weight: 500;
      color: #94a3b8;
      margin-bottom: 8px;
    }

    textarea {
      width: 100%;
      min-height: 180px;
      padding: 14px;
      background: #12141f;
      border: 1px solid #2d3148;
      border-radius: 10px;
      color: #e2e8f0;
      font-family: 'Courier New', monospace;
      font-size: 0.82rem;
      line-height: 1.6;
      resize: vertical;
      transition: border-color 0.2s;
      outline: none;
    }

    textarea:focus {
      border-color: #60a5fa;
      box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.15);
    }

    textarea::placeholder {
      color: #3d4466;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 11px 22px;
      border: none;
      border-radius: 8px;
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-primary {
      background: linear-gradient(135deg, #3b82f6, #6366f1);
      color: #fff;
    }

    .btn-primary:hover {
      background: linear-gradient(135deg, #2563eb, #4f46e5);
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(99, 102, 241, 0.4);
    }

    .btn-secondary {
      background: #1e2130;
      color: #94a3b8;
      border: 1px solid #2d3148;
    }

    .btn-secondary:hover {
      background: #252a40;
      color: #f87171;
      border-color: #f87171;
      transform: translateY(-1px);
    }

    .btn-copy {
      background: #1e2130;
      color: #60a5fa;
      border: 1px solid #2d3148;
      font-size: 0.82rem;
      padding: 7px 14px;
    }

    .btn-copy:hover {
      background: #252a40;
      border-color: #60a5fa;
    }

    .btn-copy.copied {
      color: #34d399;
      border-color: #34d399;
    }

    /* ── Stats row ── */
    .stats-row {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }

    .stat-chip {
      background: #1e2130;
      border: 1px solid #2d3148;
      border-radius: 10px;
      padding: 14px 20px;
      flex: 1;
      min-width: 140px;
      text-align: center;
    }

    .stat-chip .stat-value {
      font-size: 1.7rem;
      font-weight: 700;
      background: linear-gradient(135deg, #60a5fa, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .stat-chip .stat-label {
      font-size: 0.78rem;
      color: #64748b;
      margin-top: 4px;
    }

    /* ── Latest IDs output box ── */
    .output-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }

    #idContainer {
      background: #12141f;
      border: 1px solid #2d3148;
      border-radius: 10px;
      padding: 14px;
      font-family: 'Courier New', monospace;
      font-size: 0.82rem;
      line-height: 1.8;
      color: #a78bfa;
      white-space: pre-wrap;
      max-height: 260px;
      overflow-y: auto;
    }

    /* ── Table ── */
    .table-wrapper {
      overflow-x: auto;
      overflow-y: auto;
      max-height: 400px;
      border-radius: 10px;
      border: 1px solid #2d3148;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.83rem;
    }

    thead th {
      position: sticky;
      top: 0;
      z-index: 10;
      background: #161824;
      padding: 12px 14px;
      text-align: left;
      color: #64748b;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-bottom: 1px solid #2d3148;
    }

    tbody tr {
      transition: background 0.15s;
    }

    tbody tr:hover {
      background: rgba(96, 165, 250, 0.04);
    }

    tbody td {
      padding: 10px 14px;
      border-bottom: 1px solid #1a1d2e;
      color: #cbd5e1;
      font-family: 'Courier New', monospace;
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    /* latest row highlight */
    tbody tr.row-latest td {
      color: #e2e8f0;
    }

    tbody tr.row-latest td:nth-child(2) {
      color: #60a5fa;
      font-weight: 600;
    }

    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.05em;
    }

    .badge-latest {
      background: rgba(52, 211, 153, 0.15);
      color: #34d399;
      border: 1px solid rgba(52, 211, 153, 0.3);
    }

    .badge-old {
      background: rgba(100, 116, 139, 0.15);
      color: #64748b;
      border: 1px solid rgba(100, 116, 139, 0.2);
    }

    /* ── Tabs ── */
    .tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 16px;
    }

    .tab-btn {
      padding: 8px 18px;
      border-radius: 8px;
      border: 1px solid #2d3148;
      background: transparent;
      color: #64748b;
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }

    .tab-btn.active {
      background: #2d3148;
      color: #e2e8f0;
      border-color: #404572;
    }

    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
    }

    .footer {
      text-align: center;
      color: #64748b;
      font-size: 0.85rem;
      margin-top: 48px;
      letter-spacing: 0.05em;
    }

    .footer .heart {
      color: #ef4444;
      display: inline-block;
      animation: heartbeat 1.2s infinite;
    }

    .footer .watermark-name {
      font-weight: 600;
      background: linear-gradient(135deg, #60a5fa, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      transition: opacity 0.2s;
    }

    .footer .watermark-name:hover {
      opacity: 0.8;
    }

    @keyframes heartbeat {
      0% {
        transform: scale(1);
      }

      14% {
        transform: scale(1.12);
      }

      28% {
        transform: scale(1);
      }

      42% {
        transform: scale(1.12);
      }

      70% {
        transform: scale(1);
      }
    }

    /* scrollbar */
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }

    ::-webkit-scrollbar-track {
      background: #12141f;
    }

    ::-webkit-scrollbar-thumb {
      background: #2d3148;
      border-radius: 3px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #404572;
    }
  </style>
</head>

<body>
  <div class="page-wrapper">

    <!-- Header -->
    <div class="header">
      <h1>Annotation ID Extractor</h1>

    </div>

    <!-- Error -->
    <% if (error) { %>
      <div class="error-banner">
        <%= error %>
      </div>
      <% } %>

        <!-- Input card -->
        <div class="card">
          <div class="card-title">Input Data</div>
          <form action="/process" method="POST" id="mainForm">
            <div style="margin-bottom: 14px; font-size: 0.88rem; color: #94a3b8; line-height: 1.6;">
              <p style="margin-bottom: 6px; font-weight: 500;">Paste data in the following format (one record per line):</p>
              <div style="margin-bottom: 12px;">
                <code style="display: inline-block; background: #12141f; border: 1px solid #2d3148; padding: 6px 12px; border-radius: 6px; font-family: monospace; font-size: 0.8rem; color: #e2e8f0; width: fit-content;">Client_Token &nbsp;&nbsp;➔&nbsp;&nbsp; Annotation_ID &nbsp;&nbsp;➔&nbsp;&nbsp; Updated_Date</code>
              </div>
              <div style="margin-bottom: 8px; font-size: 0.82rem; color: #94a3b8; background: rgba(96,165,250,0.05); border-left: 3px solid #60a5fa; padding: 8px 12px; border-radius: 0 6px 6px 0;">
                <span style="font-weight: 600; color: #cbd5e1;">Required order:</span> Client_Token, Annotation_ID, Updated_Date
              </div>
              <div style="font-size: 0.82rem; color: #fca5a5; background: rgba(239,68,68,0.05); border-left: 3px solid #ef4444; padding: 8px 12px; border-radius: 0 6px 6px 0;">
                ⚠️ Do not change the column order. Separate values using tabs or multiple spaces.
              </div>
            </div>
            <textarea id="data" name="data"
              placeholder="0xDB1E323E914DC69E545712CEF18E64D2&#9;1207034696&#9;2026-06-11 20:14:45.583&#10;0x473F37701B78CA66BDFE0EC1A7080B71&#9;1207034701&#9;2026-06-11 20:15:12.120"><%= typeof data !== 'undefined' ? data : '' %></textarea>
            <div style="margin-top:16px; display:flex; gap:12px;">
              <button type="submit" class="btn btn-primary">⚡ Process</button>
              <button type="button" class="btn btn-secondary" onclick="clearAll()">🗑️ Clear</button>
            </div>
          </form>
        </div>

        <!-- Results -->
        <% if (keepRecords && keepRecords.length) { %>

          <!-- Stats -->
          <div class="stats-row">
            <div class="stat-chip">
              <div class="stat-value">
                <%= allRecords.length %>
              </div>
              <div class="stat-label">Total Rows</div>
            </div>
            <div class="stat-chip" style="border-color: rgba(52,211,153,0.3);">
              <div class="stat-value"
                style="background: linear-gradient(135deg, #34d399, #059669); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                <%= keepRecords.length %>
              </div>
              <div class="stat-label">Records to Keep</div>
            </div>
            <div class="stat-chip" style="border-color: rgba(248,113,113,0.3);">
              <div class="stat-value"
                style="background: linear-gradient(135deg, #f87171, #dc2626); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                <%= deleteRecords.length %>
              </div>
              <div class="stat-label">Records to Delete</div>
            </div>
          </div>

          <!-- Keep/Delete Copy boxes -->
          <div
            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 24px;">
            <!-- Keep box -->
            <div class="card" style="margin-bottom:0; border-color: rgba(52,211,153,0.25);">
              <div class="output-header">
                <div class="card-title" style="margin-bottom:0; color: #34d399;">Annotation IDs to KEEP</div>
                <button class="btn btn-copy" id="copyKeepBtn" onclick="copyIds('keepContainer', 'copyKeepBtn')">📋 Copy
                  KEEP IDs</button>
              </div>
              <div id="keepContainer"
                style="color: #34d399; max-height: 200px; overflow-y: auto; background: #12141f; border: 1px solid #2d3148; border-radius: 10px; padding: 14px; font-family: 'Courier New', monospace; font-size: 0.82rem; line-height: 1.8; white-space: pre-wrap;">
                <%= keepRecords.map(r=> r.id).join(', ') %>
              </div>
            </div>

            <!-- Delete box -->
            <div class="card" style="margin-bottom:0; border-color: rgba(248,113,113,0.25);">
              <div class="output-header">
                <div class="card-title" style="margin-bottom:0; color: #f87171;">Annotation IDs to DELETE</div>
                <button class="btn btn-copy" id="copyDeleteBtn" onclick="copyIds('deleteContainer', 'copyDeleteBtn')">📋
                  Copy DELETE IDs</button>
              </div>
              <div id="deleteContainer"
                style="color: #f87171; max-height: 200px; overflow-y: auto; background: #12141f; border: 1px solid #2d3148; border-radius: 10px; padding: 14px; font-family: 'Courier New', monospace; font-size: 0.82rem; line-height: 1.8; white-space: pre-wrap;">
                <%= deleteRecords.length> 0 ? deleteRecords.map(r => r.id).join(', ') : 'None' %>
              </div>
            </div>
          </div>

          <!-- Tabs for tables -->
          <div class="card">
            <div class="tabs">
              <button class="tab-btn active" onclick="switchTab('keep', this)">Keep Records (<%= keepRecords.length %>
                  )</button>
              <button class="tab-btn" onclick="switchTab('delete', this)">Delete Records (<%= deleteRecords.length %>
                  )</button>
              <button class="tab-btn" onclick="switchTab('all', this)">All Records (<%= allRecords.length %>)</button>
            </div>

            <!-- Keep table -->
            <div id="tab-keep" class="tab-panel active">
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Client Token</th>
                      <th>Annotation ID</th>
                      <th>Updated Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% keepRecords.forEach((rec, i)=> { %>
                      <tr class="row-latest" style="background: rgba(52,211,153,0.015);">
                        <td style="color:#3d4466">
                          <%= i + 1 %>
                        </td>
                        <td>
                          <%= rec.token %>
                        </td>
                        <td style="color:#34d399; font-weight:600;">
                          <%= rec.id %>
                        </td>
                        <td>
                          <%= rec.date %>
                        </td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Delete table -->
            <div id="tab-delete" class="tab-panel">
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Client Token</th>
                      <th>Annotation ID</th>
                      <th>Updated Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (deleteRecords.length===0) { %>
                      <tr>
                        <td colspan="4" style="text-align:center; color:#64748b; padding:20px;">No records marked for
                          deletion.</td>
                      </tr>
                      <% } else { %>
                        <% deleteRecords.forEach((rec, i)=> { %>
                          <tr style="background: rgba(248,113,113,0.015);">
                            <td style="color:#3d4466">
                              <%= i + 1 %>
                            </td>
                            <td>
                              <%= rec.token %>
                            </td>
                            <td style="color:#f87171; font-weight:600;">
                              <%= rec.id %>
                            </td>
                            <td>
                              <%= rec.date %>
                            </td>
                          </tr>
                          <% }) %>
                            <% } %>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- All records table -->
            <div id="tab-all" class="tab-panel">
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Client Token</th>
                      <th>Annotation ID</th>
                      <th>Updated Date</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% allRecords.forEach((rec, i)=> { %>
                      <tr class="<%= rec.isKeep ? 'row-latest' : '' %>">
                        <td style="color:#3d4466">
                          <%= i + 1 %>
                        </td>
                        <td>
                          <%= rec.token %>
                        </td>
                        <td>
                          <%= rec.id %>
                        </td>
                        <td>
                          <%= rec.date %>
                        </td>
                        <td>
                          <% if (rec.isKeep) { %>
                            <span class="badge badge-latest"
                              style="background: rgba(52,211,153,0.15); color: #34d399; border: 1px solid rgba(52,211,153,0.3);">KEEP</span>
                            <% } else { %>
                              <span class="badge badge-old"
                                style="background: rgba(248,113,113,0.15); color: #f87171; border: 1px solid rgba(248,113,113,0.3);">DELETE</span>
                              <% } %>
                        </td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <% } %>

            <div class="footer">Developed with <span class="heart">❤️</span> by <span
                class="watermark-name">RVR</span></div>
  </div>

  <script>
    function copyIds(containerId, btnId) {
      const text = document.getElementById(containerId).innerText.trim();
      const btn = document.getElementById(btnId);
      navigator.clipboard.writeText(text).then(() => {
        const originalText = btn.textContent;
        btn.textContent = "✅ Copied!";
        btn.classList.add("copied");
        setTimeout(() => { btn.textContent = originalText; btn.classList.remove("copied"); }, 2000);
      }).catch(() => alert("Failed to copy. Please copy manually."));
    }

    function switchTab(name, el) {
      document.querySelectorAll(".tab-panel").forEach(p => p.classList.remove("active"));
      document.querySelectorAll(".tab-btn").forEach(b => b.classList.remove("active"));
      document.getElementById("tab-" + name).classList.add("active");
      el.classList.add("active");
    }

    function clearAll() {
      window.location.href = "/";
    }
  </script>
</body>

</html>